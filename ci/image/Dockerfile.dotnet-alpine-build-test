FROM alpine:3.21

USER root
WORKDIR /

# Install dependencies required by .NET and test infrastructure
RUN apk update && \
    apk add --no-cache \
        bash \
        ca-certificates-bundle \
        curl \
        gnupg \
        icu-libs \
        icu-data-full \
        krb5-libs \
        libstdc++ \
        lttng-ust \
        zlib \
        openjdk11-jre \
    && rm -rf /var/cache/apk/*

# Set Java 11 as the default
ENV JAVA_HOME=/usr/lib/jvm/java-11-openjdk
ENV PATH="${JAVA_HOME}/bin:${PATH}"

# Install .NET SDKs using Microsoft's install script.
# Alpine's repos do not carry .NET packages; Microsoft's rpm/deb feeds do not target musl.
ENV DOTNET_ROOT=/usr/share/dotnet
ENV PATH="${PATH}:${DOTNET_ROOT}:${DOTNET_ROOT}/tools"
RUN curl -sSL https://dot.net/v1/dotnet-install.sh -o /tmp/dotnet-install.sh && \
    chmod +x /tmp/dotnet-install.sh && \
    /tmp/dotnet-install.sh --channel 9.0 --install-dir ${DOTNET_ROOT} && \
    rm /tmp/dotnet-install.sh && \
    dotnet --list-sdks

# Use ICU for globalization (not invariant mode)
ENV DOTNET_SYSTEM_GLOBALIZATION_INVARIANT=false

# Install dotnet-coverage tool to shared location (accessible by any user)
ARG DOTNET_COVERAGE_VERSION
ENV DOTNET_TOOLS=/opt/dotnet-tools
ENV PATH="${PATH}:${DOTNET_TOOLS}"
RUN dotnet tool install --tool-path ${DOTNET_TOOLS} dotnet-coverage --version ${DOTNET_COVERAGE_VERSION} && \
    dotnet-coverage --version

# Accept user ID as build argument to match host permissions
ARG USER_ID=1001
ARG GROUP_ID=1001

# Create user for proper permission testing
RUN addgroup -g ${GROUP_ID} user && \
    adduser -u ${USER_ID} -G user -D -s /bin/bash user && \
    mkdir -p /home/user && \
    chown -R user:user /home/user

USER user
WORKDIR /home/user
