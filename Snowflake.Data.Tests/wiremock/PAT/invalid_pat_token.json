{
    "mappings": [
        {
            "scenarioName": "Invalid PAT authentication flow",
            "request": {
                "urlPathPattern": "/session/v1/login-request",
                "method": "POST",
                "headers": {
                    "Authorization": {
                        "equalTo": "Basic"
                    }
                },
                "bodyPatterns": [
                    { "matchesJsonPath": "$.data[?(@.ACCOUNT_NAME == 'MOCK_ACCOUNT_NAME')]" },
                    { "matchesJsonPath": "$.data[?(@.TOKEN == 'MOCK_TOKEN')]" },
                    { "matchesJsonPath": "$.data[?(@.LOGIN_NAME == 'MOCK_USERNAME')]" },
                    { "matchesJsonPath": "$.data[?(@.AUTHENTICATOR == 'programmatic_access_token')]" }
                ]
            },
            "response": {
                "status": 200,
                "jsonBody": {
                    "data": {
                        "nextAction": "RETRY_LOGIN",
                        "authnMethod": "PAT",
                        "signInOptions": {}
                    },
                    "code": "394400",
                    "message": "Programmatic access token is invalid.",
                    "success": false,
                    "headers": null
                }
            }
        }
    ]
}
